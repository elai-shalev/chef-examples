[Unit]
Description=Redis persistent key-value database
After=network.target

[Service]
ExecStart={{ redis_install_dir | default('/usr/local/bin') }}/redis-server /etc/redis/{{ item.port }}.conf
ExecStop={{ redis_install_dir | default('/usr/local/bin') }}/redis-cli -p {{ item.port }} shutdown
User=redis
Group=redis
RuntimeDirectory=redis
RuntimeDirectoryMode=0755
LimitNOFILE={{ redis_nofile_limit | default(10240) }}

[Install]
WantedBy=multi-user.target