# Redis configuration file
# Generated by Ansible

# Network
bind {{ item.bind | default('0.0.0.0') }}
port {{ item.port }}
protected-mode yes
tcp-backlog 511
timeout 0
tcp-keepalive 300

# General
daemonize yes
supervised systemd
pidfile {{ redis_pid_dir | default('/var/run/redis') }}/redis_{{ item.port }}.pid
loglevel notice
logfile {{ redis_log_dir | default('/var/log/redis') }}/redis_{{ item.port }}.log

# Memory management
maxmemory {{ item.maxmemory | default('100mb') }}
maxmemory-policy {{ item.maxmemory_policy | default('volatile-lru') }}

# Persistence
dir {{ redis_data_dir | default('/var/lib/redis') }}
dbfilename dump_{{ item.port }}.rdb
save 900 1
save 300 10
save 60 10000
stop-writes-on-bgsave-error yes
rdbcompression yes
rdbchecksum yes

# Security
{% if item.requirepass is defined and item.requirepass %}
requirepass {{ item.requirepass }}
{% endif %}

# Limits
maxclients {{ item.maxclients | default(10000) }}