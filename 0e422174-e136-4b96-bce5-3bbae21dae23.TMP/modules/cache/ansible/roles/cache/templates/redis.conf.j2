# Redis configuration file

# General
daemonize yes
pidfile /var/run/redis/{{ redis_port | default('6379') }}.pid
port {{ redis_port | default('6379') }}
tcp-backlog 511
bind {{ redis_bind | default('0.0.0.0') }}
timeout {{ redis_timeout | default('0') }}
tcp-keepalive {{ redis_tcp_keepalive | default('0') }}
loglevel {{ redis_loglevel | default('notice') }}
logfile /var/log/redis/redis_{{ redis_port | default('6379') }}.log
databases {{ redis_databases | default('16') }}

# Snapshotting
{% for save in redis_save %}
save {{ save }}
{% endfor %}
stop-writes-on-bgsave-error {{ redis_stop_writes_on_bgsave_error | default('yes') }}
rdbcompression {{ redis_rdbcompression | default('yes') }}
rdbchecksum {{ redis_rdbchecksum | default('yes') }}
dbfilename dump-{{ redis_port | default('6379') }}.rdb
dir {{ redis_datadir | default('/var/lib/redis') }}

# Replication
{% if redis_slaveof is defined %}
slaveof {{ redis_slaveof }}
{% endif %}
{% if redis_slave_serve_stale_data is defined %}
slave-serve-stale-data {{ redis_slave_serve_stale_data }}
{% endif %}
{% if redis_slave_read_only is defined %}
slave-read-only {{ redis_slave_read_only }}
{% endif %}
{% if redis_repl_ping_slave_period is defined %}
repl-ping-slave-period {{ redis_repl_ping_slave_period }}
{% endif %}
{% if redis_repl_timeout is defined %}
repl-timeout {{ redis_repl_timeout }}
{% endif %}
{% if redis_repl_disable_tcp_nodelay is defined %}
repl-disable-tcp-nodelay {{ redis_repl_disable_tcp_nodelay }}
{% endif %}
{% if redis_repl_backlog_size is defined %}
repl-backlog-size {{ redis_repl_backlog_size }}
{% endif %}
{% if redis_repl_backlog_ttl is defined %}
repl-backlog-ttl {{ redis_repl_backlog_ttl }}
{% endif %}
{% if redis_slave_priority is defined %}
slave-priority {{ redis_slave_priority }}
{% endif %}
{% if redis_min_slaves_to_write is defined %}
min-slaves-to-write {{ redis_min_slaves_to_write }}
{% endif %}
{% if redis_min_slaves_max_lag is defined %}
min-slaves-max-lag {{ redis_min_slaves_max_lag }}
{% endif %}

# Security
{% if redis_requirepass is defined and redis_requirepass != '' %}
requirepass {{ redis_requirepass }}
{% endif %}
{% if redis_rename_commands is defined %}
{% for command in redis_rename_commands %}
rename-command {{ command }}
{% endfor %}
{% endif %}

# Limits
maxclients {{ redis_maxclients | default('10000') }}
maxmemory {{ redis_maxmemory | default('0') }}
maxmemory-policy {{ redis_maxmemory_policy | default('volatile-lru') }}
maxmemory-samples {{ redis_maxmemory_samples | default('3') }}

# Append Only Mode
appendonly {{ redis_appendonly | default('no') }}
appendfilename "appendonly-{{ redis_port | default('6379') }}.aof"
appendfsync {{ redis_appendfsync | default('everysec') }}
no-appendfsync-on-rewrite {{ redis_no_appendfsync_on_rewrite | default('no') }}
auto-aof-rewrite-percentage {{ redis_auto_aof_rewrite_percentage | default('100') }}
auto-aof-rewrite-min-size {{ redis_auto_aof_rewrite_min_size | default('64mb') }}
aof-load-truncated {{ redis_aof_load_truncated | default('yes') }}

# Lua scripting
lua-time-limit {{ redis_lua_time_limit | default('5000') }}

# Slow log
slowlog-log-slower-than {{ redis_slowlog_log_slower_than | default('10000') }}
slowlog-max-len {{ redis_slowlog_max_len | default('128') }}

# Latency monitor
latency-monitor-threshold {{ redis_latency_monitor_threshold | default('0') }}

# Event notification
notify-keyspace-events "{{ redis_notify_keyspace_events | default('') }}"

# Advanced config
hash-max-ziplist-entries {{ redis_hash_max_ziplist_entries | default('512') }}
hash-max-ziplist-value {{ redis_hash_max_ziplist_value | default('64') }}
list-max-ziplist-entries {{ redis_list_max_ziplist_entries | default('512') }}
list-max-ziplist-value {{ redis_list_max_ziplist_value | default('64') }}
set-max-intset-entries {{ redis_set_max_intset_entries | default('512') }}
zset-max-ziplist-entries {{ redis_zset_max_ziplist_entries | default('128') }}
zset-max-ziplist-value {{ redis_zset_max_ziplist_value | default('64') }}
hll-sparse-max-bytes {{ redis_hll_sparse_max_bytes | default('3000') }}
activerehashing {{ redis_activerehashing | default('yes') }}
client-output-buffer-limit normal {{ redis_client_output_buffer_limit_normal | default('0 0 0') }}
client-output-buffer-limit slave {{ redis_client_output_buffer_limit_slave | default('256mb 64mb 60') }}
client-output-buffer-limit pubsub {{ redis_client_output_buffer_limit_pubsub | default('32mb 8mb 60') }}
hz {{ redis_hz | default('10') }}
aof-rewrite-incremental-fsync {{ redis_aof_rewrite_incremental_fsync | default('yes') }}