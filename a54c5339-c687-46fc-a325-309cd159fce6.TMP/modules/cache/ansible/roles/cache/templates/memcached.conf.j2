# memcached default config file
# Generated by Ansible

# Run memcached as a daemon
-d

# Log file location
logfile {{ memcached_logfile }}

# Use {{ memcached_memory }}MB memory max
-m {{ memcached_memory }}

# Default connection port is 11211
-p {{ memcached_port }}

# Run as user
-u {{ memcached_user }}

# Listen on IP address
-l {{ memcached_listen }}

# Max simultaneous connections
-c {{ memcached_maxconn }}

# Additional options
{% if memcached_extra_options is defined %}
{{ memcached_extra_options }}
{% endif %}