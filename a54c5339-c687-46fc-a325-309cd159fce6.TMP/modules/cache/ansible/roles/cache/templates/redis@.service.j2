[Unit]
Description=Redis persistent key-value database
After=network.target

[Service]
ExecStart={{ redis_install_dir | default('/usr/bin') }}/redis-server {{ redis_conf_dir | default('/etc/redis') }}/%i.conf
ExecStop={{ redis_install_dir | default('/usr/bin') }}/redis-cli -p %i shutdown
Type=simple
User={{ redis_user | default('redis') }}
Group={{ redis_group | default('redis') }}
RuntimeDirectory=redis
RuntimeDirectoryMode=0755
LimitNOFILE={{ redis_nofile_limit | default('65536') }}

[Install]
WantedBy=multi-user.target