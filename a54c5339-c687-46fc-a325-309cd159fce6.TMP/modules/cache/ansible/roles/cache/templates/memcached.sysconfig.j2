# memcached default config file for RHEL/CentOS
# Generated by Ansible

PORT="{{ memcached_port }}"
USER="{{ memcached_user }}"
MAXCONN="{{ memcached_maxconn }}"
CACHESIZE="{{ memcached_memory }}"
OPTIONS="-l {{ memcached_listen }}{% if memcached_logfile %} -o logfile={{ memcached_logfile }}{% endif %}{% if memcached_extra_options is defined %} {{ memcached_extra_options }}{% endif %}"