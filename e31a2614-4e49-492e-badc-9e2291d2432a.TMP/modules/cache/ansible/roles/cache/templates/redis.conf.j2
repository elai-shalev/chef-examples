# Redis configuration file
# Generated by Ansible

# General
port {{ item.port }}
daemonize yes
pidfile /var/run/redis/redis-{{ item.port }}.pid
logfile /var/log/redis/redis-{{ item.port }}.log
dir /var/lib/redis/{{ item.port }}

# Network
bind 0.0.0.0
tcp-backlog 511
timeout 0
tcp-keepalive 0

# Security
{% if item.requirepass is defined and item.requirepass %}
requirepass {{ item.requirepass }}
{% endif %}

# Memory Management
maxmemory-policy noeviction

# Replication
{% if item.replicaservestaledata is defined %}
replica-serve-stale-data {{ 'yes' if item.replicaservestaledata else 'no' }}
{% endif %}

# Persistence
save 900 1
save 300 10
save 60 10000
stop-writes-on-bgsave-error yes
rdbcompression yes
rdbchecksum yes
dbfilename dump.rdb

# Advanced
hash-max-ziplist-entries 512
hash-max-ziplist-value 64
list-max-ziplist-entries 512
list-max-ziplist-value 64
set-max-intset-entries 512
zset-max-ziplist-entries 128
zset-max-ziplist-value 64
activerehashing yes
client-output-buffer-limit normal 0 0 0
client-output-buffer-limit slave 256mb 64mb 60
client-output-buffer-limit pubsub 32mb 8mb 60
hz 10
aof-rewrite-incremental-fsync yes