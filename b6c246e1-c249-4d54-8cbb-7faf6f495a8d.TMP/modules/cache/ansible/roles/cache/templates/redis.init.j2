#!/bin/sh
#
# Redis init script
# Generated by Ansible
#
# chkconfig: 2345 95 20
# description: Redis server daemon
#
### BEGIN INIT INFO
# Provides: redis{{ item.port | default('6379') }}
# Required-Start: $network $local_fs $remote_fs
# Required-Stop: $network $local_fs $remote_fs
# Default-Start: 2 3 4 5
# Default-Stop: 0 1 6
# Short-Description: Redis data structure server
# Description: Redis is an open source, advanced key-value store
### END INIT INFO

# Source function library
[ -f /etc/rc.d/init.d/functions ] && . /etc/rc.d/init.d/functions
[ -f /etc/sysconfig/redis{{ item.port | default('6379') }} ] && . /etc/sysconfig/redis{{ item.port | default('6379') }}

# Source networking configuration
[ -f /etc/sysconfig/network ] && . /etc/sysconfig/network

# Check networking is up
[ "$NETWORKING" = "no" ] && exit 0

REDIS_USER={{ redis_user | default('redis') }}
REDIS_GROUP={{ redis_group | default('redis') }}
REDIS_HOME={{ redis_home | default('/var/lib/redis') }}
REDIS_PORT={{ item.port | default('6379') }}
REDIS_CONF_PATH={{ redis_conf_path | default('/etc/redis') }}
REDIS_CONF_FILE=$REDIS_CONF_PATH/$REDIS_PORT.conf
REDIS_PID_PATH={{ redis_pid_path | default('/var/run/redis') }}
REDIS_PID_FILE=$REDIS_PID_PATH/$REDIS_PORT.pid
REDIS_EXECUTABLE={{ redis_executable | default('/usr/local/bin/redis-server') }}

start() {
    [ -f $REDIS_CONF_FILE ] || exit 6
    [ -x $REDIS_EXECUTABLE ] || exit 5
    echo -n "Starting Redis server: "
    daemon --user $REDIS_USER "$REDIS_EXECUTABLE $REDIS_CONF_FILE"
    RETVAL=$?
    echo
    [ $RETVAL -eq 0 ] && touch /var/lock/subsys/redis$REDIS_PORT
    return $RETVAL
}

stop() {
    echo -n "Stopping Redis server: "
    killproc -p $REDIS_PID_FILE redis-server
    RETVAL=$?
    echo
    [ $RETVAL -eq 0 ] && rm -f /var/lock/subsys/redis$REDIS_PORT
    return $RETVAL
}

restart() {
    stop
    start
}

case "$1" in
    start)
        start
        ;;
    stop)
        stop
        ;;
    status)
        status -p $REDIS_PID_FILE redis-server
        RETVAL=$?
        ;;
    restart|force-reload)
        restart
        ;;
    condrestart|try-restart)
        [ -f /var/lock/subsys/redis$REDIS_PORT ] && restart || :
        ;;
    *)
        echo "Usage: $0 {start|stop|status|restart|condrestart|try-restart|force-reload}"
        exit 2
esac
exit $RETVAL