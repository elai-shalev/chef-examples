# Redis Sentinel configuration file
# Generated by Ansible

port {{ item.port | default('26379') }}
dir "/var/lib/redis/sentinel_{{ item.port | default('26379') }}"
daemonize yes
pidfile "/var/run/redis/sentinel_{{ item.port | default('26379') }}.pid"
logfile "/var/log/redis/sentinel_{{ item.port | default('26379') }}.log"

sentinel monitor {{ item.master_name | default('mymaster') }} {{ item.master_ip | default('127.0.0.1') }} {{ item.master_port | default('6379') }} {{ item.quorum | default('2') }}
sentinel down-after-milliseconds {{ item.master_name | default('mymaster') }} {{ item.down_after_milliseconds | default('30000') }}
sentinel parallel-syncs {{ item.master_name | default('mymaster') }} {{ item.parallel_syncs | default('1') }}
sentinel failover-timeout {{ item.master_name | default('mymaster') }} {{ item.failover_timeout | default('180000') }}

{% if item.auth_pass is defined %}
sentinel auth-pass {{ item.master_name | default('mymaster') }} {{ item.auth_pass }}
{% endif %}

{% if item.notification_script is defined %}
sentinel notification-script {{ item.master_name | default('mymaster') }} {{ item.notification_script }}
{% endif %}

{% if item.client_reconfig_script is defined %}
sentinel client-reconfig-script {{ item.master_name | default('mymaster') }} {{ item.client_reconfig_script }}
{% endif %}