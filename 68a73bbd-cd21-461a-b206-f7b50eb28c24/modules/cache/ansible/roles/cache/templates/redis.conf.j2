# Redis configuration file

# Network
bind {{ redis_bind_interface }}
port {{ redis_port }}
protected-mode yes

# General
daemonize yes
supervised systemd
pidfile /var/run/redis/redis-server.pid
loglevel {{ redis_log_level }}
logfile {{ redis_log_dir }}/redis_{{ redis_port }}.log

# Security
requirepass {{ redis_password }}

# Memory Management
maxmemory {{ redis_maxmemory }}
maxmemory-policy {{ redis_maxmemory_policy }}

# Persistence
dir /var/lib/redis
dbfilename dump.rdb
save 900 1
save 300 10
save 60 10000
stop-writes-on-bgsave-error yes
rdbcompression yes
rdbchecksum yes

# Advanced
databases {{ redis_databases }}
tcp-backlog 511
tcp-keepalive 300
timeout 0

# Note: The following lines are intentionally removed as per the original recipe's ruby_block:
# replica-serve-stale-data
# replica-read-only
# repl-ping-replica-period
# client-output-buffer-limit
# replica-priority