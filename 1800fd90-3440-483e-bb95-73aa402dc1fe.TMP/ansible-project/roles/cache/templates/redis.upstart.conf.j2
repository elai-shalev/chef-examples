description "Redis Server {{ port | default('6379') }}"

start on runlevel [23]
stop on shutdown

pre-start script
    mkdir -p /var/run/redis/{{ port | default('6379') }}
    chown redis:redis /var/run/redis/{{ port | default('6379') }}
end script

exec su -s /bin/sh -c "/usr/bin/redis-server /etc/redis/{{ port | default('6379') }}.conf" redis

respawn