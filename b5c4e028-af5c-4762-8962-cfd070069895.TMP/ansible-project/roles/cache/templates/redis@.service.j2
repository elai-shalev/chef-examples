[Unit]
Description=Redis persistent key-value database
After=network.target

[Service]
ExecStart=/usr/local/bin/redis-server /etc/redis/%i.conf
ExecStop=/usr/local/bin/redis-cli -p %i shutdown
User={{ redis_user | default('redis') }}
Group={{ redis_group | default('redis') }}
RuntimeDirectory=redis
RuntimeDirectoryMode=0755
LimitNOFILE={{ redis_nofile_limit | default('65536') }}

[Install]
WantedBy=multi-user.target