#!/bin/sh
#
# Redis init script
# Generated by Ansible
#
# chkconfig: 2345 95 20
# description: Redis server daemon
#
### BEGIN INIT INFO
# Provides: redis_{{ redis_port }}
# Required-Start: $network $local_fs $remote_fs
# Required-Stop: $network $local_fs $remote_fs
# Default-Start: 2 3 4 5
# Default-Stop: 0 1 6
# Short-Description: Redis data structure server
# Description: Redis is an open source, advanced key-value store
### END INIT INFO

# Source function library
[ -f /etc/rc.d/init.d/functions ] && . /etc/rc.d/init.d/functions
[ -f /lib/lsb/init-functions ] && . /lib/lsb/init-functions

REDIS_PORT="{{ redis_port }}"
REDIS_USER="{{ redis_user | default('redis') }}"
REDIS_GROUP="{{ redis_group | default('redis') }}"
REDIS_EXEC="{{ redis_install_dir | default('/usr/local') }}/bin/redis-server"
REDIS_CLI="{{ redis_install_dir | default('/usr/local') }}/bin/redis-cli"
REDIS_CONF="/etc/redis/${REDIS_PORT}.conf"
REDIS_PIDFILE="{{ redis_pidfile }}"

case "$1" in
    start)
        echo -n "Starting Redis server on port ${REDIS_PORT}: "
        if [ -f $REDIS_PIDFILE ]; then
            echo "Already running"
            exit 1
        fi
        if [ -x $REDIS_EXEC ]; then
            su -s /bin/sh -c "$REDIS_EXEC $REDIS_CONF" $REDIS_USER
            echo "OK"
        else
            echo "Redis server not found"
            exit 1
        fi
        ;;
    stop)
        echo -n "Stopping Redis server on port ${REDIS_PORT}: "
        if [ -f $REDIS_PIDFILE ]; then
            $REDIS_CLI -p $REDIS_PORT shutdown
            echo "OK"
        else
            echo "Not running"
        fi
        ;;
    restart)
        $0 stop
        sleep 1
        $0 start
        ;;
    status)
        if [ -f $REDIS_PIDFILE ]; then
            PID=$(cat $REDIS_PIDFILE)
            if [ -d /proc/$PID ]; then
                echo "Redis server is running on port ${REDIS_PORT}"
                exit 0
            else
                echo "Redis server is not running (but PID file exists)"
                exit 1
            fi
        else
            echo "Redis server is not running"
            exit 3
        fi
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|status}"
        exit 1
        ;;
esac

exit 0