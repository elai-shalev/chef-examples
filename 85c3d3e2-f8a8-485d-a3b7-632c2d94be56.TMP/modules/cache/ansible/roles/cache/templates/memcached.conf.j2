# memcached default config file
# 2003 - Jay Bonci <jaybonci@debian.org>
# This configuration file is read by the start-memcached script provided by
# the memcached package.

# Run memcached as a daemon
-d

# Log memcached's output to /var/log/memcached
logfile /var/log/memcached/memcached.log

# Memory cap for each instance (MB)
-m {{ memcached_memory | default('64') }}

# Default connection port is 11211
-p {{ memcached_port | default('11211') }}

# Run the daemon as memcache user
-u memcache

# Specify which IP address to listen on. Default is to listen on all IP addresses
-l {{ memcached_listen | default('0.0.0.0') }}

# Limit the number of simultaneous incoming connections
-c {{ memcached_maxconn | default('1024') }}

# Use UDP for transport
-U {{ memcached_port | default('11211') }}

# Enable large memory pages if available
# -L

# Disable flush_all command
# -F

# Return error when memory is exhausted (rather than removing items)
# -M