[Unit]
Description=Redis persistent key-value database
After=network.target

[Service]
ExecStart={{ redis_install_dir | default('/usr/local') }}/bin/redis-server /etc/redis/%i.conf
ExecStop={{ redis_install_dir | default('/usr/local') }}/bin/redis-cli -p %i shutdown
User={{ redis_user | default('redis') }}
Group={{ redis_group | default('redis') }}
RuntimeDirectory=redis
RuntimeDirectoryMode=0755
LimitNOFILE={{ redis_ulimit_nofile | default('65536') }}

[Install]
WantedBy=multi-user.target