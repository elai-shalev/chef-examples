[Unit]
Description=Redis persistent key-value database
After=network.target

[Service]
ExecStart={{ redis_install_dir }}/bin/redis-server /etc/redis/%i.conf
ExecStop={{ redis_install_dir }}/bin/redis-cli -p %i {{ redis_requirepass | ternary('-a ' ~ redis_requirepass, '') }} shutdown
User=redis
Group=redis
RuntimeDirectory=redis
RuntimeDirectoryMode=0755
LimitNOFILE={{ redis_nofile_limit | default('10240') }}

[Install]
WantedBy=multi-user.target