[Unit]
Description=Redis instance {{ item.port }}
After=network.target

[Service]
Type=forking
ExecStart=/usr/bin/redis-server {{ redis_conf_dir }}/{{ item.port }}.conf
PIDFile=/var/run/redis/redis-{{ item.port }}.pid
TimeoutStopSec=0
Restart=always
User={{ redis_user }}
Group={{ redis_group }}
RuntimeDirectory=redis
RuntimeDirectoryMode=0755

[Install]
WantedBy=multi-user.target