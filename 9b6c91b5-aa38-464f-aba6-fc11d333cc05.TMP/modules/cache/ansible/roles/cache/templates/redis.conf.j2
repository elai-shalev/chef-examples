# Redis configuration file
# Generated by Ansible

# Network
bind {{ item.bind | default('127.0.0.1') }}
port {{ item.port }}
{% if item.unixsocket %}
unixsocket {{ item.unixsocket }}
unixsocketperm {{ item.unixsocketperm | default('755') }}
{% endif %}
tcp-backlog 511
timeout {{ item.timeout | default('0') }}
tcp-keepalive {{ item.tcp_keepalive | default('0') }}

# General
daemonize {{ item.daemonize | default('yes') }}
pidfile {{ item.pidfile | default('/var/run/redis/redis-' + item.port + '.pid') }}
loglevel notice
logfile {{ item.logfile | default('/var/log/redis/redis-' + item.port + '.log') }}
databases {{ item.databases | default('16') }}

# Snapshotting
{% if item.save %}
{% for save_rule in item.save %}
save {{ save_rule }}
{% endfor %}
{% else %}
save 900 1
save 300 10
save 60 10000
{% endif %}
stop-writes-on-bgsave-error yes
rdbcompression yes
rdbchecksum yes
dbfilename dump.rdb
dir {{ item.dir | default('/var/lib/redis/' + item.port) }}

# Replication
{% if item.slaveof %}
slaveof {{ item.slaveof.masterip }} {{ item.slaveof.masterport }}
{% endif %}
{% if item.slaveof and item.slaveof.masterauth %}
masterauth {{ item.slaveof.masterauth }}
{% endif %}

# Security
{% if item.requirepass %}
requirepass {{ item.requirepass }}
{% endif %}

# Limits
maxclients {{ item.maxclients | default('10000') }}
{% if item.maxmemory %}
maxmemory {{ item.maxmemory }}
maxmemory-policy {{ item.maxmemory_policy | default('volatile-lru') }}
maxmemory-samples 3
{% endif %}

# Append only mode
appendonly no
appendfilename "appendonly.aof"
appendfsync everysec
no-appendfsync-on-rewrite no
auto-aof-rewrite-percentage 100
auto-aof-rewrite-min-size 64mb
aof-load-truncated yes

# LUA scripting
lua-time-limit 5000

# Slow log
slowlog-log-slower-than 10000
slowlog-max-len 128

# Event notification
notify-keyspace-events ""

# Advanced config
hash-max-ziplist-entries 512
hash-max-ziplist-value 64
list-max-ziplist-entries 512
list-max-ziplist-value 64
set-max-intset-entries 512
zset-max-ziplist-entries 128
zset-max-ziplist-value 64
hll-sparse-max-bytes 3000
activerehashing yes
client-output-buffer-limit normal 0 0 0
client-output-buffer-limit slave 256mb 64mb 60
client-output-buffer-limit pubsub 32mb 8mb 60
hz 10
aof-rewrite-incremental-fsync yes