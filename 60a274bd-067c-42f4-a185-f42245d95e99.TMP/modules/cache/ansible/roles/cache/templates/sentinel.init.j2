#!/bin/sh
#
# Redis Sentinel init script for Debian/Ubuntu and CentOS
# Generated by Ansible
#
# chkconfig: - 85 15
# description: Redis Sentinel monitors Redis instances
#
### BEGIN INIT INFO
# Provides:          redis-sentinel{{ redis_sentinel_port | default('26379') }}
# Required-Start:    $network $local_fs $remote_fs
# Required-Stop:     $network $local_fs $remote_fs
# Default-Start:     2 3 4 5
# Default-Stop:      0 1 6
# Short-Description: Redis Sentinel
# Description:       Redis Sentinel monitors Redis instances and provides failover
### END INIT INFO

# Source function library
if [ -f /etc/rc.d/init.d/functions ]; then
    . /etc/rc.d/init.d/functions
fi

if [ -f /etc/init.d/functions ]; then
    . /etc/init.d/functions
fi

if [ -f /lib/lsb/init-functions ]; then
    . /lib/lsb/init-functions
fi

SENTINEL_PORT={{ redis_sentinel_port | default('26379') }}
EXEC=/usr/bin/redis-sentinel
CLIEXEC=/usr/bin/redis-cli
PIDFILE=/var/run/redis/sentinel_${SENTINEL_PORT}.pid
CONF="/etc/redis-sentinel/${SENTINEL_PORT}.conf"
REDISUSER=redis

case "$1" in
    start)
        if [ -f $PIDFILE ]
        then
                echo "$PIDFILE exists, process is already running or crashed"
        else
                echo "Starting Redis Sentinel..."
                if [ -n "$REDISUSER" ]
                then
                    su $REDISUSER -c "$EXEC $CONF"
                else
                    $EXEC $CONF
                fi
        fi
        ;;
    stop)
        if [ ! -f $PIDFILE ]
        then
                echo "$PIDFILE does not exist, process is not running"
        else
                PID=$(cat $PIDFILE)
                echo "Stopping Redis Sentinel..."
                $CLIEXEC -p $SENTINEL_PORT shutdown
                while [ -x /proc/${PID} ]
                do
                    echo "Waiting for Redis Sentinel to shutdown ..."
                    sleep 1
                done
                echo "Redis Sentinel stopped"
        fi
        ;;
    status)
        if [ ! -f $PIDFILE ]
        then
                echo "Redis Sentinel is not running"
                exit 1
        else
                PID=$(cat $PIDFILE)
                if [ -x /proc/${PID} ]
                then
                    echo "Redis Sentinel is running"
                    exit 0
                else
                    echo "Redis Sentinel is not running but $PIDFILE exists"
                    exit 1
                fi
        fi
        ;;
    restart)
        $0 stop
        $0 start
        ;;
    *)
        echo "Please use start, stop, restart or status as first argument"
        ;;
esac