# Redis Sentinel configuration
# Generated by Ansible

port {{ redis_sentinel_port | default('26379') }}
dir {{ redis_sentinel_dir | default('/tmp') }}
daemonize yes
pidfile /var/run/redis/sentinel_{{ redis_sentinel_port | default('26379') }}.pid
logfile /var/log/redis/sentinel_{{ redis_sentinel_port | default('26379') }}.log

{% if redis_sentinel_bind is defined %}
bind {{ redis_sentinel_bind }}
{% endif %}

{% if redis_sentinel_monitors is defined %}
{% for monitor in redis_sentinel_monitors %}
sentinel monitor {{ monitor.name }} {{ monitor.host }} {{ monitor.port }} {{ monitor.quorum }}
{% if monitor.auth_pass is defined %}
sentinel auth-pass {{ monitor.name }} {{ monitor.auth_pass }}
{% endif %}
{% if monitor.down_after_milliseconds is defined %}
sentinel down-after-milliseconds {{ monitor.name }} {{ monitor.down_after_milliseconds }}
{% endif %}
{% if monitor.parallel_syncs is defined %}
sentinel parallel-syncs {{ monitor.name }} {{ monitor.parallel_syncs }}
{% endif %}
{% if monitor.failover_timeout is defined %}
sentinel failover-timeout {{ monitor.name }} {{ monitor.failover_timeout }}
{% endif %}
{% if monitor.notification_script is defined %}
sentinel notification-script {{ monitor.name }} {{ monitor.notification_script }}
{% endif %}
{% if monitor.client_reconfig_script is defined %}
sentinel client-reconfig-script {{ monitor.name }} {{ monitor.client_reconfig_script }}
{% endif %}
{% endfor %}
{% else %}
# No sentinel monitors defined
{% endif %}

{% if redis_sentinel_extra_config is defined %}
# Extra configuration options
{% for key, value in redis_sentinel_extra_config.items() %}
{{ key }} {{ value }}
{% endfor %}
{% endif %}