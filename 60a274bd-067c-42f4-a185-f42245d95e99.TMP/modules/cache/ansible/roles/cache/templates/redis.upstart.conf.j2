# Redis Upstart configuration
# Generated by Ansible

description "Redis Server"
author "Ansible"

start on runlevel [2345]
stop on runlevel [016]

respawn
respawn limit 10 5

setuid redis
setgid redis

limit nofile {{ redis_ulimit | default('65536') }} {{ redis_ulimit | default('65536') }}

expect fork

pre-start script
    mkdir -p /var/run/redis
    chown redis:redis /var/run/redis
end script

exec /usr/bin/redis-server /etc/redis/{{ redis_port | default('6379') }}.conf